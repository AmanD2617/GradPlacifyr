PORT=3000
JWT_SECRET=your-secret-key-change-in-production
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=placement_portal

# Prisma — single connection string used by @prisma/client
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/placement_portal

# SMTP (Gmail) for OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Default Admin Bootstrap ─────────────────────────────────────────────────
# On server startup, if no user with role='admin' exists in the database,
# one is auto-created from these values. Password MUST meet the strength
# rules (min 8 chars, upper, lower, digit, special). Log in with this
# account and change the password immediately after first boot.
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=ChangeMe@123!
DEFAULT_ADMIN_NAME=System Administrator
